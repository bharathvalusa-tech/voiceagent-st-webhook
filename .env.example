# Inbound agents for which post-call job creation is DISABLED (comma-separated
# agent_ids). For these agents (e.g. office-hours / after-hours) the ServiceTrade
# job is decided post the outbound dispatch call and only if  the technician approves it — never auto-created post-call by the webhook.
POSTCALL_JOB_DISABLED_AGENT_IDS="agent_b2c640200a45d2f4b7d8ad8d28,agent_052cc725604f449c8725ef2718,agent_efbe503faedf1bf516f961979f"

# Adaptive Climates Apps Script web-app /exec URL. The outbound post-call webhook
# (/webhook/retell-outbound) POSTs the job result here (action:"job_update") so the
# escalation sheet row is updated with is_job_created / job_number / outcome.
# Use the same /exec value that the Vercel ADAPTIVE_EXEC_URL points at.
ADAPTIVE_SHEET_EXEC_URL="https://script.google.com/macros/s/AKfycby63gtzO8qen26D8-FviCFsW3JAJPRhCa7qHy2msmwuvdKMVK-e7MgwI9AnhafG2FYJAA/exec"

# Inbound agent id that owns the Adaptive ServiceTrade token/config. The outbound
# post-call webhook resolves the ST config from this when the outbound call did not
# carry an inbound_agent_id (Adaptive uses one ST account).
ST_CONTEXT_DEFAULT_AGENT_ID="agent_efbe503faedf1bf516f961979f"

