# Inbound agents for which post-call job creation is DISABLED (comma-separated
# agent_ids). For these agents (e.g. office-hours / after-hours) the ServiceTrade
# job is decided live on the outbound dispatch call when the technician approves
# it — never auto-created post-call by the webhook.
POSTCALL_JOB_DISABLED_AGENT_IDS="agent_b2c640200a45d2f4b7d8ad8d28, agent_052cc725604f449c8725ef2718"

# Optional fallback inbound agent_id used by /st-create-job-from-context when the
# outbound call doesn't supply inbound_agent_id. Set to the inbound agent that
# owns the ServiceTrade token.
ST_CONTEXT_DEFAULT_AGENT_ID=""
